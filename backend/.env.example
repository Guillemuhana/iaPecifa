# ====== CONFIGURACIÓN DEL AGENTE PECIFA ======
# Copiá este archivo como ".env" y completá con tus claves reales.
# NUNCA subas el archivo .env a internet ni a GitHub.

# --- Groq (la IA que responde) ---
# Sacá tu clave gratis en: https://console.groq.com/keys
GROQ_API_KEY=tu_clave_de_groq_aca

# --- Supabase (la base de datos con los documentos) ---
# Sacá estos datos en: tu proyecto Supabase > Settings > API
SUPABASE_URL=https://tuproyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_aca

# --- Resend (para enviar los emails de consultas) ---
# Sacá tu clave gratis en: https://resend.com/api-keys
RESEND_API_KEY=tu_clave_de_resend_aca

# Email de PECIFA al que llegan las consultas de los afiliados
EMAIL_PECIFA=asistentegremial@pecifa.org

# Email remitente. Al principio dejá el de prueba de Resend.
# Más adelante, si verificás tu dominio en Resend, podés poner uno @pecifa.org
EMAIL_REMITENTE=onboarding@resend.dev

# --- Puerto del servidor (dejalo así) ---
PORT=3001

# --- Modelo de Groq (dejalo así, es el recomendado gratis) ---
GROQ_MODEL=llama-3.3-70b-versatile

# --- ElevenLabs (voz realista del delegado) ---
# Sacá tu clave gratis en: https://elevenlabs.io (Profile > API Keys)
ELEVENLABS_API_KEY=tu_clave_de_elevenlabs_aca

# Voz a usar. Por defecto una voz en español. Podés cambiarla por el ID
# de otra voz desde tu cuenta de ElevenLabs (Voice Library).
ELEVENLABS_VOICE_ID=
